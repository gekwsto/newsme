generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum ArticleType {
  NEWS
  EVERGREEN
  OPINION
  GUIDE
}

enum Role {
  ADMIN
  EDITOR
}

enum ArticleStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  PUBLISHED
  REJECTED
}

enum SourceType {
  MANUAL
  AI_GENERATED
  AI_ASSISTED
  RSS_SUMMARY
}

enum SocialPlatform {
  FACEBOOK
  INSTAGRAM
  TWITTER
  LINKEDIN
}

enum SocialPostStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  SCHEDULED
  PUBLISHED
  REJECTED
  FAILED
}

enum ApprovalAction {
  APPROVED
  REJECTED
}

enum DiscoveredStatus {
  NEW
  DRAFT_CREATED
  IGNORED
}

enum ScheduledPostStatus {
  PENDING
  PUBLISHED
  FAILED
  CANCELLED
}

enum QueueItemStatus {
  QUEUED
  SCHEDULED
  PUBLISHED
  FAILED
  CANCELLED
}

enum TrainingDataType {
  NEWS_RSS
  NEWS_MANUAL
  EVERGREEN
}

enum PipelineRunStatus {
  RUNNING
  COMPLETED
  FAILED
  SKIPPED
}

enum ImageStatus {
  NONE
  PENDING
  GENERATED
  FAILED
  RSS_AVAILABLE
  RSS_SELECTED
  AI_PENDING
  AI_GENERATED
  AI_FAILED
  MANUAL_UPLOADED
}

enum SystemEventStatus {
  OK
  WARNING
  ERROR
}

// ─── Models ───────────────────────────────────────────────────────────────────

model User {
  id           String     @id @default(cuid())
  name         String
  email        String     @unique
  passwordHash String
  role         Role       @default(EDITOR)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  articles     Article[]
  approvals    Approval[]

  @@map("users")
}

model Category {
  id                 String              @id @default(cuid())
  name               String
  slug               String              @unique
  color              String              @default("#6366f1")
  articles           Article[]
  rssSources         RssSource[]
  discoveredArticles DiscoveredArticle[]

  @@map("categories")
}

model Tag {
  id       String       @id @default(cuid())
  name     String       @unique
  articles ArticleTag[]

  @@map("tags")
}

model Article {
  id                String        @id @default(cuid())
  title             String
  slug              String        @unique
  excerpt           String
  content           String        @db.Text
  coverImage        String?
  coverImagePrompt  String?       @db.Text
  generatedImageUrl String?
  suggestedImageUrl String?
  imageStatus       ImageStatus   @default(NONE)
  imageSource       String?
  imageAttribution  String?
  imageProvider     String?
  imageCostEstimate Float?
  status            ArticleStatus @default(DRAFT)
  articleType       ArticleType   @default(NEWS)
  sourceType        SourceType    @default(MANUAL)
  aiCommentary      String?       @db.Text
  seoTitle          String?
  seoDescription    String?
  seoScore            Int?
  evergreenKeyword    String?
  secondaryKeywords   String[]      @default([])
  faqJson             Json?
  searchIntent        String?
  estimatedDifficulty Int?
  qualityScore       Float?
  aiSeoScore         Float?
  readabilityScore   Float?
  views               Int           @default(0)
  readTime          Int           @default(3)
  publishedAt       DateTime?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])

  authorId String
  author   User    @relation(fields: [authorId], references: [id])

  tags                 ArticleTag[]
  aiDraft              AiDraft?
  trainingExample      TrainingExample?
  socialPosts          SocialPost[]
  approvals            Approval[]
  scheduledPosts       ScheduledPost[]
  publishQueueItems    PublishQueueItem[]
  searchConsoleMetrics SearchConsoleMetric[]

  @@map("articles")
}

model ArticleTag {
  articleId String
  tagId     String
  article   Article @relation(fields: [articleId], references: [id], onDelete: Cascade)
  tag       Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([articleId, tagId])
  @@map("article_tags")
}

model AiDraft {
  id               String   @id @default(cuid())
  articleId        String   @unique
  article          Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  prompt           String   @db.Text
  rawOutput        String   @db.Text
  model            String   @default("gpt-4o")
  imagePrompt      String?  @db.Text
  promptVersion    String?
  generatorVersion String?
  createdAt        DateTime @default(now())

  @@map("ai_drafts")
}

model SocialPost {
  id             String           @id @default(cuid())
  articleId      String
  article        Article          @relation(fields: [articleId], references: [id], onDelete: Cascade)
  platform       SocialPlatform
  content        String           @db.Text
  status         SocialPostStatus @default(DRAFT)
  scheduledAt    DateTime?
  publishedAt    DateTime?
  externalPostId String?
  errorMessage   String?          @db.Text
  createdAt      DateTime         @default(now())
  performance      PostPerformance?
  scheduledPost    ScheduledPost?
  publishQueueItem PublishQueueItem?

  @@map("social_posts")
}

model Approval {
  id         String         @id @default(cuid())
  articleId  String
  article    Article        @relation(fields: [articleId], references: [id], onDelete: Cascade)
  reviewerId String
  reviewer   User           @relation(fields: [reviewerId], references: [id])
  action     ApprovalAction
  note       String?
  createdAt  DateTime       @default(now())

  @@map("approvals")
}

model RssSource {
  id                  String              @id @default(cuid())
  name                String
  url                 String              @unique
  categoryId          String
  category            Category            @relation(fields: [categoryId], references: [id])
  enabled             Boolean             @default(true)
  allowAutoGeneration Boolean             @default(false)
  language            String              @default("EN")
  country             String              @default("GLOBAL")
  reliabilityScore    Int                 @default(70)
  feedSourceType      String              @default("NEWS")
  lastFetchedAt       DateTime?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  articles            DiscoveredArticle[]

  @@map("rss_sources")
}

model EvergreenAutomationSettings {
  id                 String   @id @default(cuid())
  isEnabled          Boolean  @default(false)
  allowedHours       Int[]    @default([9, 20])
  targetDraftCount   Int      @default(3)
  articlesPerRun     Int      @default(2)
  dailyAiBudgetLimit Float    @default(2.0)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@map("evergreen_automation_settings")
}

model NewsAutomationSettings {
  id                     String   @id @default(cuid())
  rssScanIntervalMinutes Int      @default(60)
  maxNewsPerDay          Int      @default(6)
  publishMode            String   @default("DRAFT")
  facebookAutoPost       Boolean  @default(false)
  allowedPublishHours    Int[]    @default([10, 13, 15, 18, 21, 23])
  minimumImportanceScore Int      @default(7)
  compoundScoreThreshold Int      @default(45)
  dailyAiBudgetLimit     Float    @default(0.80)
  isEnabled              Boolean  @default(true)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  @@map("news_automation_settings")
}

model CategoryImageSettings {
  id            String   @id @default(cuid())
  categoryId    String   @unique
  imageMode     String   @default("TEMPLATE")
  templateColor String   @default("#6366f1")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("category_image_settings")
}

model DiscoveredArticle {
  id             String           @id @default(cuid())
  sourceId       String
  source         RssSource        @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  title          String
  url            String           @unique
  excerpt        String?          @db.Text
  publishedAt    DateTime?
  categoryId     String
  category       Category         @relation(fields: [categoryId], references: [id])
  status         DiscoveredStatus @default(NEW)
  imageUrl       String?
  localScore     Int?
  filteredReason String?
  // ── Semantic filter fields ─────────────────────────────────────────────────
  semanticScore             Int?
  matchedKeywords           Json?
  semanticCategory          String?
  semanticSecondaryCategory String?
  passedSemanticFilter      Boolean  @default(false)
  // ── Compound scoring fields ────────────────────────────────────────────────
  compoundScore         Float?
  compoundReason        String?
  selectedForGeneration Boolean  @default(false)
  // ── Article extraction ────────────────────────────────────────────────────
  sourceArticleBody   String?  @db.Text
  extractionSuccess   Boolean?
  extractionMethod    String?
  extractionWordCount Int?
  // ──────────────────────────────────────────────────────────────────────────
  clusterId      String?
  cluster        TrendCluster?    @relation(fields: [clusterId], references: [id], onDelete: SetNull)
  clusterPrimary Boolean          @default(false)
  // ── Human review labels (for classifier training data) ────────────────────
  humanVerdict     String?   // 'accepted' | 'rejected'
  humanVerdictAt   DateTime?
  humanVerdictNote String?
  // ──────────────────────────────────────────────────────────────────────────
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  score          ContentScore?

  @@map("discovered_articles")
}

model ContentScore {
  id                   String            @id @default(cuid())
  discoveredArticleId  String            @unique
  discoveredArticle    DiscoveredArticle @relation(fields: [discoveredArticleId], references: [id], onDelete: Cascade)
  greekInterestScore   Int               @default(0)
  searchPotentialScore Int               @default(0)
  facebookClickScore   Int               @default(0)
  evergreenScore       Int               @default(0)
  overallScore         Int               @default(0)
  rejected             Boolean           @default(false)
  rejectReason         String?           @db.Text
  reasoning            String?           @db.Text
  scoredAt             DateTime          @default(now())

  @@map("content_scores")
}

model TrendCluster {
  id           String              @id @default(cuid())
  topic        String
  trendScore   Int                 @default(0)
  articleCount Int                 @default(0)
  sourceCount  Int                 @default(0)
  firstSeenAt  DateTime            @default(now())
  lastSeenAt   DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  articles     DiscoveredArticle[]

  @@map("trend_clusters")
}

model PostPerformance {
  id                 String     @id @default(cuid())
  socialPostId       String     @unique
  socialPost         SocialPost @relation(fields: [socialPostId], references: [id], onDelete: Cascade)
  predictedReach     Int        @default(0)
  predictedComments  Int        @default(0)
  predictedShares    Int        @default(0)
  actualReach        Int        @default(0)
  actualComments     Int        @default(0)
  actualShares       Int        @default(0)
  actualReactions    Int        @default(0)
  predictionAccuracy Int?
  learningWeight     Float      @default(1.0)
  lastSyncedAt       DateTime?
  createdAt          DateTime   @default(now())

  @@map("post_performances")
}

model TopicPerformance {
  id               String   @id @default(cuid())
  topic            String   @unique
  category         String   @default("")
  avgReach         Float    @default(0)
  avgComments      Float    @default(0)
  avgShares        Float    @default(0)
  avgReactions     Float    @default(0)
  avgDiscussionScore Float  @default(0)
  avgFacebookScore Float    @default(0)
  articleCount     Int      @default(0)
  performanceScore Float    @default(0)
  updatedAt        DateTime @updatedAt
  createdAt        DateTime @default(now())

  @@map("topic_performances")
}

model EvergreenOpportunity {
  id             String   @id @default(cuid())
  topic          String
  primaryKeyword String
  articleType    String   @default("guide")
  category       String   @default("")
  seoScore       Int      @default(0)
  businessValue  Int      @default(0)
  difficulty     Int      @default(50)
  evergreenValue Int      @default(0)
  fbReusability  Int      @default(0)
  overallScore   Int      @default(0)
  clusterTopics  String[] @default([])
  status         String   @default("new")
  reasoning      String?  @db.Text
  generatedAt    DateTime @default(now())

  @@map("evergreen_opportunities")
}

model ScheduledPost {
  id           String              @id @default(cuid())
  articleId    String
  article      Article             @relation(fields: [articleId], references: [id], onDelete: Cascade)
  socialPostId String              @unique
  socialPost   SocialPost          @relation(fields: [socialPostId], references: [id], onDelete: Cascade)
  platform     SocialPlatform
  scheduledFor DateTime
  status       ScheduledPostStatus @default(PENDING)
  publishedAt  DateTime?
  errorMessage String?             @db.Text
  createdAt    DateTime            @default(now())

  @@map("scheduled_posts")
}

model PublishQueueItem {
  id            String          @id @default(cuid())
  articleId     String
  article       Article         @relation(fields: [articleId], references: [id], onDelete: Cascade)
  socialPostId  String?         @unique
  socialPost    SocialPost?     @relation(fields: [socialPostId], references: [id], onDelete: SetNull)
  queuePosition Int             @default(0)
  priority      Int             @default(1)
  scheduledFor  DateTime?
  status        QueueItemStatus @default(QUEUED)
  publishedAt   DateTime?
  errorMessage  String?         @db.Text
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@map("publish_queue_items")
}

model SystemEvent {
  id        String            @id @default(cuid())
  service   String
  type      String
  status    SystemEventStatus
  message   String            @db.Text
  metadata  Json?
  createdAt DateTime          @default(now())

  @@index([createdAt(sort: Desc)])
  @@index([service, status, createdAt(sort: Desc)])
  @@index([status, createdAt(sort: Desc)])
  @@map("system_events")
}

model SearchConsoleMetric {
  id              String   @id @default(cuid())
  articleId       String
  article         Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  keyword         String
  impressions     Int      @default(0)
  clicks          Int      @default(0)
  ctr             Float    @default(0)
  averagePosition Float    @default(0)
  date            DateTime @db.Date
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([articleId, keyword, date])
  @@index([articleId])
  @@index([keyword])
  @@index([date(sort: Desc)])
  @@map("search_console_metrics")
}

model KeywordOpportunity {
  id              String   @id @default(cuid())
  keyword         String   @unique
  impressions     Int      @default(0)
  clicks          Int      @default(0)
  ctr             Float    @default(0)
  avgPosition     Float    @default(0)
  clusterSlug     String?
  topicSuggestion String?
  status          String   @default("new")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([status])
  @@index([clusterSlug])
  @@map("keyword_opportunities")
}

// ─── Image Library ─────────────────────────────────────────────────────────────

model ImageCategory {
  id           String                @id @default(cuid())
  name         String
  slug         String                @unique
  description  String?
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt
  tags         ImageTag[]
  collections  ImageCollection[]
  assets       ImageAsset[]
  defaultImage ImageCategoryDefault?

  @@map("image_categories")
}

model ImageTag {
  id         String        @id @default(cuid())
  name       String
  slug       String
  categoryId String
  category   ImageCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  assets     ImageAsset[]

  @@unique([slug, categoryId])
  @@map("image_tags")
}

model ImageCollection {
  id          String        @id @default(cuid())
  name        String
  slug        String
  categoryId  String
  category    ImageCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  description String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  assets      ImageAsset[]

  @@unique([slug, categoryId])
  @@map("image_collections")
}

model ImageAsset {
  id               String             @id @default(cuid())
  categoryId       String
  category         ImageCategory      @relation(fields: [categoryId], references: [id])
  tagId            String?
  tag              ImageTag?          @relation(fields: [tagId], references: [id])
  collectionId     String?
  collection       ImageCollection?   @relation(fields: [collectionId], references: [id], onDelete: SetNull)
  pexelsId         Int?               @unique
  localPath        String
  publicUrl        String
  originalUrl      String?
  photographer     String?
  photographerUrl  String?
  pexelsUrl        String?
  uploadSource     String             @default("pexels")
  width            Int
  height           Int
  altText          String
  description      String?
  qualityScore     Int                @default(5)
  seasonStart      String?
  seasonEnd        String?
  theme            String             @default("global")
  usedCount        Int                @default(0)
  lastUsedAt       DateTime?
  isActive         Boolean            @default(true)
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  usages           ArticleImageUsage[]
  keywords         ImageKeyword[]
  performance      ImagePerformance?
  categoryDefaults ImageCategoryDefault[]

  @@index([categoryId, isActive, theme])
  @@index([tagId])
  @@index([collectionId])
  @@map("image_assets")
}

model ImageKeyword {
  id           String     @id @default(cuid())
  imageAssetId String
  imageAsset   ImageAsset @relation(fields: [imageAssetId], references: [id], onDelete: Cascade)
  keyword      String
  aliases      Json       @default("[]")
  isPriority   Boolean    @default(false)
  isOverride   Boolean    @default(false)
  createdAt    DateTime   @default(now())

  @@unique([imageAssetId, keyword])
  @@index([imageAssetId])
  @@map("image_keywords")
}

model ImagePerformance {
  id             String     @id @default(cuid())
  imageAssetId   String     @unique
  imageAsset     ImageAsset @relation(fields: [imageAssetId], references: [id], onDelete: Cascade)
  totalArticles  Int        @default(0)
  totalViews     Int        @default(0)
  totalClicks    Int        @default(0)
  avgCtr         Float?
  avgReadingTime Float?
  avgScrollDepth Float?
  lastSyncedAt   DateTime?
  updatedAt      DateTime   @updatedAt

  @@map("image_performance")
}

model ImageCategoryDefault {
  id           String        @id @default(cuid())
  categoryId   String        @unique
  category     ImageCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  imageAssetId String
  imageAsset   ImageAsset    @relation(fields: [imageAssetId], references: [id], onDelete: Cascade)

  @@map("image_category_defaults")
}

model ImageSelectionSettings {
  id                     String   @id @default(cuid())
  categoryWeight         Float    @default(40)
  subcategoryWeight      Float    @default(30)
  priorityKeywordWeight  Float    @default(25)
  keywordWeight          Float    @default(10)
  exactPhraseWeight      Float    @default(15)
  multiKeyword2Bonus     Float    @default(10)
  multiKeyword3Bonus     Float    @default(20)
  qualityScoreWeight     Float    @default(1)
  overrideBonus          Float    @default(1000)
  recentUsage1dPenalty   Float    @default(-15)
  recentUsage3dPenalty   Float    @default(-10)
  recentUsage7dPenalty   Float    @default(-5)
  usageCountPenalty      Float    @default(-1)
  usageCountCap          Float    @default(-20)
  updatedAt              DateTime @updatedAt

  @@map("image_selection_settings")
}

model ArticleImageUsage {
  id           String     @id @default(cuid())
  articleId    String
  imageAssetId String
  imageAsset   ImageAsset @relation(fields: [imageAssetId], references: [id])
  createdAt    DateTime   @default(now())

  @@index([articleId])
  @@map("article_image_usages")
}

// ─── Training Data ─────────────────────────────────────────────────────────────

model TrainingExample {
  id                  String           @id @default(cuid())
  articleId           String           @unique
  article             Article          @relation(fields: [articleId], references: [id], onDelete: Cascade)

  // Optional link to the RSS article that triggered generation
  discoveredArticleId String?

  // Source material (the raw input that was fed to the model)
  sourceTitle         String           @db.Text
  sourceExcerpt       String?          @db.Text
  sourceUrl           String?
  sourceName          String?

  // The prompt/completion pair (core training signal)
  dataType            TrainingDataType
  systemPrompt        String           @db.Text
  userPrompt          String           @db.Text
  aiCompletion        String           @db.Text  // full JSON string returned by GPT
  model               String

  // Structured extracted fields (for easy filtering/searching)
  generatedTitle      String
  generatedExcerpt    String           @db.Text
  generatedTags       String[]
  category            String?

  // Version tracking
  promptVersion       String?
  generatorVersion    String?

  // Semantic context
  matchedKeywords     String[]         @default([])
  semanticCategory    String?
  compoundScore       Float?

  // Quality signals (populated by human actions)
  wasEdited           Boolean          @default(false)
  wasPublished        Boolean          @default(false)
  wasRejected         Boolean          @default(false)
  humanRating         Int?             // 1-5, for future manual quality tagging

  // Final state snapshot (taken at publish time)
  finalTitle          String?
  finalContent        String?          @db.Text

  // Export control
  includeInExport     Boolean          @default(true)

  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt

  @@index([dataType, createdAt(sort: Desc)])
  @@index([wasPublished, createdAt(sort: Desc)])
  @@map("training_examples")
}

model PipelineRun {
  id                    String            @id @default(cuid())
  status                PipelineRunStatus @default(RUNNING)
  startedAt             DateTime          @default(now())
  finishedAt            DateTime?
  forceRun              Boolean           @default(false)

  // Feed stats
  totalFeeds            Int               @default(0)
  failedFeeds           Int               @default(0)
  fetchedItems          Int               @default(0)

  // Filter funnel
  skippedDuplicates     Int               @default(0)
  localRejected         Int               @default(0)
  semanticRejected      Int               @default(0)
  compoundRejected      Int               @default(0)
  selectedForGeneration Int               @default(0)

  // Generation results
  generatedArticles     Int               @default(0)
  failedGenerations     Int               @default(0)

  // Context
  modelUsed             String?
  promptVersion         String?
  generatorVersion      String?
  compoundThreshold     Float?

  // Outcome
  reason                String?
  errorMessage          String?           @db.Text

  items                 PipelineRunItem[]

  @@index([startedAt(sort: Desc)])
  @@map("pipeline_runs")
}

model PipelineRunItem {
  id                    String       @id @default(cuid())
  runId                 String
  run                   PipelineRun  @relation(fields: [runId], references: [id], onDelete: Cascade)

  sourceName            String
  rssTitle              String       @db.Text
  rssUrl                String

  localScore            Float?
  semanticScore         Float?
  compoundScore         Float?
  semanticCategory      String?
  matchedKeywords       String[]     @default([])
  resolvedCategory      String?
  semanticBreakdown     Json?
  extractionStatus      String?
  extractionWordCount   Int?

  selectedForGeneration Boolean      @default(false)
  generatedArticleId    String?
  generationStatus      String?
  failureReason         String?      @db.Text

  createdAt             DateTime     @default(now())

  @@index([runId])
  @@map("pipeline_run_items")
}
